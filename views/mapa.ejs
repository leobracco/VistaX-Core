<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>VistaX — Mapa de Siembra</title>
    <link rel="stylesheet" href="/css/all.min.css" />
    <link rel="stylesheet" href="/css/leaflet.min.css" />
    <style>
      :root {
        --bg: #0a0a0a;
        --card: #141414;
        --border: #2a2a2a;
        --accent: #00e676;
        --danger: #ff1744;
        --warning: #ffb300;
        --muted: #555;
        --panel-w: 280px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: #e8e8e8;
        font-family: "Segoe UI", system-ui, sans-serif;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      /* ---- BARRA SUPERIOR ---- */
      .map-topbar {
        height: 52px;
        background: var(--card);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        padding: 0 14px;
        gap: 12px;
        flex-shrink: 0;
      }

      .topbar-brand {
        font-size: 18px;
        font-weight: 900;
        color: var(--accent);
        letter-spacing: -1px;
        flex-shrink: 0;
      }
      .topbar-brand span {
        font-size: 9px;
        font-weight: 400;
        color: var(--muted);
        display: block;
        letter-spacing: 0;
      }
      .topbar-sep {
        width: 1px;
        height: 28px;
        background: var(--border);
        flex-shrink: 0;
      }

      .lote-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 5px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid var(--border);
        color: var(--muted);
        background: #111;
      }
      .lote-badge.activo {
        background: #0d2b1a;
        border-color: #1a5c35;
        color: var(--accent);
      }

      .rec-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--danger);
        animation: blink 1s infinite;
        flex-shrink: 0;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.1;
        }
      }

      .topbar-kpis {
        display: flex;
        gap: 20px;
        margin-left: auto;
      }
      .tkpi {
        text-align: right;
      }
      .tkpi small {
        display: block;
        font-size: 8px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 700;
      }
      .tkpi strong {
        font-size: 18px;
        font-weight: 700;
      }
      .tkpi strong.ok {
        color: var(--accent);
      }
      .tkpi strong.err {
        color: var(--danger);
      }

      .btn {
        padding: 7px 13px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #111;
        color: #ccc;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: filter 0.15s;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .btn:hover {
        filter: brightness(1.3);
      }
      .btn-start {
        background: #0d2b1a;
        border-color: #1a5c35;
        color: var(--accent);
      }
      .btn-stop {
        background: #2b0d0d;
        border-color: #5c1a1a;
        color: var(--danger);
      }
      .btn-export {
        background: #1a1a2b;
        border-color: #2a2a5c;
        color: #7b8cff;
      }
      .btn-back {
        color: var(--muted);
      }

      /* ---- LAYOUT ---- */
      .map-body {
        flex: 1;
        display: flex;
        overflow: hidden;
      }

      .side-panel {
        width: var(--panel-w);
        background: var(--card);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        flex-shrink: 0;
      }
      .panel-section {
        padding: 13px;
        border-bottom: 1px solid var(--border);
      }
      .panel-section h4 {
        font-size: 9px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: 0.06em;
      }

      .legend-gradient {
        height: 12px;
        border-radius: 4px;
        background: linear-gradient(
          to right,
          #ff1744,
          #ffb300,
          #ffea00,
          #00e676
        );
        margin-bottom: 5px;
      }
      .legend-labels {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: var(--muted);
      }

      .stat-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 7px;
      }
      .stat-box {
        background: #0a0a0a;
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 7px 9px;
      }
      .stat-box small {
        display: block;
        font-size: 8px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 700;
        margin-bottom: 2px;
      }
      .stat-box strong {
        font-size: 16px;
        font-weight: 700;
      }

      .layer-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        margin-bottom: 7px;
        cursor: pointer;
      }
      .layer-row input {
        accent-color: var(--accent);
        cursor: pointer;
      }

      .surcos-lista {
        display: flex;
        flex-direction: column;
        gap: 3px;
        max-height: 200px;
        overflow-y: auto;
      }
      .surco-row {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 11px;
        padding: 4px 5px;
        border-radius: 3px;
        cursor: pointer;
        transition: background 0.1s;
      }
      .surco-row:hover {
        background: #1a1a1a;
      }
      .surco-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .surco-num {
        color: var(--muted);
        min-width: 55px;
      }
      .surco-val {
        font-weight: 700;
        margin-left: auto;
      }
      .surco-alerta .surco-val {
        color: var(--danger);
      }

      .historial-item {
        padding: 9px 10px;
        background: #0a0a0a;
        border: 1px solid var(--border);
        border-radius: 5px;
        margin-bottom: 7px;
        cursor: pointer;
        transition: border-color 0.15s;
      }
      .historial-item:hover {
        border-color: #444;
      }
      .historial-item.activo {
        border-color: var(--accent);
        background: #0d2b1a22;
      }
      .hi-nombre {
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 3px;
      }
      .hi-meta {
        font-size: 10px;
        color: var(--muted);
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      /* ---- MAPA ---- */
      #map {
        flex: 1;
        background: #0a0a0a;
      }
      .leaflet-container {
        background: #0a0a0a !important;
      }
      .leaflet-control-zoom a {
        background: #1e1e1e !important;
        color: #aaa !important;
        border-color: #333 !important;
      }
      .leaflet-control-attribution {
        background: rgba(0, 0, 0, 0.5) !important;
        color: #333 !important;
      }
      .leaflet-tooltip {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
      }

      .surco-tip {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 6px;
        padding: 8px 11px;
        font-size: 11px;
        color: #ccc;
        min-width: 130px;
        pointer-events: none;
      }
      .surco-tip .st-num {
        font-size: 10px;
        color: var(--muted);
        font-weight: 700;
        text-transform: uppercase;
      }
      .surco-tip .st-spm {
        font-size: 22px;
        font-weight: 900;
        line-height: 1;
      }
      .surco-tip .st-alrt {
        color: var(--danger);
        font-size: 10px;
        font-weight: 700;
        margin-top: 3px;
      }
      .surco-tip .st-meta {
        font-size: 10px;
        color: #444;
        margin-top: 3px;
      }

      /* ---- MODAL NUEVO LOTE ---- */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }
      .modal-overlay.hidden {
        display: none !important;
      }
      .modal-box {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 10px;
        padding: 26px;
        width: 360px;
      }
      .modal-box h3 {
        font-size: 15px;
        color: var(--accent);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .fg {
        margin-bottom: 13px;
      }
      .fg label {
        display: block;
        font-size: 9px;
        color: var(--muted);
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 5px;
      }
      .fg input,
      .fg select {
        width: 100%;
        background: #111;
        border: 1px solid #333;
        color: white;
        padding: 9px 11px;
        border-radius: 5px;
        font-size: 14px;
      }
      .fg input:focus,
      .fg select:focus {
        outline: none;
        border-color: var(--accent);
      }
      .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 18px;
      }
      .modal-actions .btn {
        flex: 1;
        justify-content: center;
        padding: 10px;
      }

      /* ---- MODAL DETALLE SURCO ---- */
      .detalle-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10000;
      }
      .detalle-overlay.abierto {
        display: flex;
      }
      .detalle-box {
        background: #141414;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        min-width: 260px;
        max-width: 300px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
      }
      .detalle-header {
        background: #1e1e1e;
        padding: 14px 18px;
        border-bottom: 1px solid #222;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .detalle-tipo {
        font-size: 10px;
        color: #555;
        font-weight: 700;
        text-transform: uppercase;
      }
      .detalle-titulo {
        font-size: 18px;
        font-weight: 900;
        color: white;
      }
      .detalle-close {
        background: transparent;
        border: none;
        color: #555;
        font-size: 24px;
        cursor: pointer;
        line-height: 1;
        padding: 0 4px;
      }
      .detalle-close:hover {
        color: var(--danger);
      }
      .detalle-body {
        padding: 18px;
      }
      .detalle-spm-label {
        font-size: 11px;
        color: #555;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 6px;
        text-align: center;
      }
      .detalle-spm-valor {
        font-size: 52px;
        font-weight: 900;
        line-height: 1;
        text-align: center;
      }
      .detalle-spm-unidad {
        font-size: 13px;
        color: #444;
        text-align: center;
        margin-bottom: 14px;
      }
      .detalle-barra-bg {
        background: #0a0a0a;
        border-radius: 4px;
        overflow: hidden;
        height: 6px;
        margin-bottom: 6px;
      }
      .detalle-barra-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.3s;
      }
      .detalle-barra-labels {
        display: flex;
        justify-content: space-between;
        font-size: 9px;
        color: #333;
        margin-bottom: 14px;
      }
      .detalle-tapado {
        background: #2b0d0d;
        border: 1px solid #5c1a1a;
        border-radius: 6px;
        padding: 10px;
        text-align: center;
        color: var(--danger);
        font-weight: 700;
        font-size: 12px;
      }

      /* ---- TOAST ---- */
      .toast {
        position: fixed;
        bottom: 18px;
        right: 18px;
        background: #1a1a1a;
        border: 1px solid var(--accent);
        border-radius: 7px;
        padding: 11px 16px;
        font-size: 12px;
        color: var(--accent);
        z-index: 9998;
        transform: translateY(60px);
        opacity: 0;
        transition: all 0.3s;
        pointer-events: none;
      }
      .toast.show {
        transform: translateY(0);
        opacity: 1;
      }
      .toast.error {
        border-color: var(--danger);
        color: var(--danger);
      }

      ::-webkit-scrollbar {
        width: 4px;
        height: 4px;
      }
      ::-webkit-scrollbar-track {
        background: #000;
      }
      ::-webkit-scrollbar-thumb {
        background: #2a2a2a;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <%# Inyección de variables del servidor — ANTES de cualquier script %>
    <script>
      window.APP_CONFIG  = <%- JSON.stringify(config    || {}) %>;
      window.LOTE_ACTIVO = <%- JSON.stringify(loteActivo || null) %>;
    </script>

    <!-- BARRA SUPERIOR -->
    <div class="map-topbar">
      <div class="topbar-brand">
        VistaX <span>MAPA DE SIEMBRA — POR SURCO</span>
      </div>
      <div class="topbar-sep"></div>

      <div class="lote-badge" id="lote-badge">
        <i class="fas fa-seedling"></i>
        <span id="txt-lote-nombre">SIN LOTE ACTIVO</span>
      </div>
      <div class="rec-dot" id="rec-dot" style="display: none"></div>

      <button
        class="btn btn-start"
        id="btn-iniciar"
        onclick="MapUI.abrirModalIniciar()"
      >
        <i class="fas fa-play-circle"></i> INICIAR LOTE
      </button>
      <button
        class="btn btn-stop"
        id="btn-cerrar"
        onclick="MapUI.cerrarLote()"
        style="display: none"
      >
        <i class="fas fa-stop-circle"></i> CERRAR LOTE
      </button>
      <button
        class="btn btn-export"
        id="btn-export"
        onclick="MapUI.exportarLote()"
        style="display: none"
      >
        <i class="fas fa-download"></i> .geojson
      </button>

      <div class="topbar-kpis">
        <div class="tkpi">
          <small>S/M prom.</small><strong id="hkpi-spm" class="ok">—</strong>
        </div>
        <div class="tkpi">
          <small>Puntos GPS</small><strong id="hkpi-pts">0</strong>
        </div>
        <div class="tkpi">
          <small>Alertas</small><strong id="hkpi-alertas" class="err">0</strong>
        </div>
        <div class="tkpi">
          <small>Área</small><strong id="hkpi-ha">— ha</strong>
        </div>
      </div>

      <div class="topbar-sep"></div>
      <a href="/" class="btn btn-back"
        ><i class="fas fa-tachometer-alt"></i> Monitor</a
      >
    </div>

    <!-- BODY -->
    <div class="map-body">
      <aside class="side-panel">
        <div class="panel-section">
          <h4>
            <i class="fas fa-palette" style="margin-right: 4px"></i>Densidad por
            surco (s/m)
          </h4>
          <div class="legend-gradient"></div>
          <div class="legend-labels">
            <span>Tapado</span><span id="leg-mid">—</span
            ><span id="leg-max">óptimo+</span>
          </div>
          <div
            style="
              margin-top: 8px;
              font-size: 10px;
              color: #333;
              line-height: 1.6;
            "
          >
            Cada círculo = 1 surco físico<br />
            Click en círculo o fila → detalle
          </div>
        </div>

        <div class="panel-section">
          <h4>
            <i class="fas fa-chart-bar" style="margin-right: 4px"></i
            >Estadísticas
          </h4>
          <div class="stat-grid">
            <div class="stat-box">
              <small>Área aprox.</small><strong id="stat-ha">—</strong
              ><small style="font-size: 8px; color: #333">ha</small>
            </div>
            <div class="stat-box">
              <small>Recorrido</small><strong id="stat-dist">—</strong
              ><small style="font-size: 8px; color: #333">m</small>
            </div>
            <div class="stat-box">
              <small>s/m mín.</small
              ><strong id="stat-min" style="color: var(--warning)">—</strong>
            </div>
            <div class="stat-box">
              <small>s/m máx.</small
              ><strong id="stat-max" style="color: var(--accent)">—</strong>
            </div>
          </div>
        </div>

        <div class="panel-section">
          <h4>
            <i class="fas fa-stream" style="margin-right: 4px"></i>Surcos —
            lectura actual
          </h4>
          <div class="surcos-lista" id="surcos-lista">
            <div
              style="
                font-size: 10px;
                color: #333;
                text-align: center;
                padding: 8px;
              "
            >
              Sin datos aún
            </div>
          </div>
        </div>

        <div class="panel-section">
          <h4>
            <i class="fas fa-layer-group" style="margin-right: 4px"></i>Capas
          </h4>
          <label class="layer-row"
            ><input
              type="checkbox"
              id="toggle-surcos"
              checked
              onchange="MapEngine.toggleCapa('surcos')"
            />
            <span>Surcos individuales</span></label
          >
          <label class="layer-row"
            ><input
              type="checkbox"
              id="toggle-alertas"
              checked
              onchange="MapEngine.toggleCapa('alertas')"
            /><span>Alertas</span></label
          >
          <label class="layer-row"
            ><input
              type="checkbox"
              id="toggle-track"
              checked
              onchange="MapEngine.toggleCapa('track')"
            /><span>Trayectoria GPS</span></label
          >
        </div>

        <div class="panel-section" style="flex: 1">
          <h4>
            <i class="fas fa-history" style="margin-right: 4px"></i>Historial
          </h4>
          <div id="historial-lista"></div>
        </div>
      </aside>

      <div id="map"></div>
    </div>

    <!-- MODAL NUEVO LOTE -->
    <div class="modal-overlay hidden" id="modal-lote-nuevo">
      <div class="modal-box">
        <h3><i class="fas fa-seedling"></i> Nuevo lote de siembra</h3>
        <div class="fg">
          <label>Nombre del lote</label>
          <input
            type="text"
            id="inp-nombre"
            placeholder="Ej: Potrero Norte"
            onkeydown="if (event.key === 'Enter') MapUI.iniciarLote();"
          />
        </div>
        <div class="fg">
          <label>Cultivo</label>
          <select id="inp-cultivo">
            <option>Soja</option>
            <option>Maíz</option>
            <option>Girasol</option>
            <option>Trigo</option>
            <option>Sorgo</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="fg">
          <label>Distancia entre surcos (m)</label>
          <input
            type="number"
            id="inp-ancho"
            value="<%= (config && config.setup && config.setup.distancia_entre_surcos) ? config.setup.distancia_entre_surcos : 0.191 %>"
            step="0.001"
            min="0.05"
            max="2"
          />
        </div>
        <div class="fg">
          <label>Surco central sobre el GPS (0 = auto)</label>
          <input
            type="number"
            id="inp-surco-centro"
            value="0"
            step="1"
            min="0"
          />
          <small
            style="
              color: #444;
              font-size: 10px;
              display: block;
              margin-top: 4px;
            "
            >0 = centro del array de surcos</small
          >
        </div>
        <div class="modal-actions">
          <button class="btn" onclick="MapUI.cerrarModalIniciar()">
            Cancelar
          </button>
          <button class="btn btn-start" onclick="MapUI.iniciarLote()">
            <i class="fas fa-play-circle"></i> Iniciar
          </button>
        </div>
      </div>
    </div>

    <!-- MODAL DETALLE SURCO -->
    <div class="detalle-overlay" id="detalle-overlay">
      <div class="detalle-box">
        <div class="detalle-header">
          <div>
            <div class="detalle-tipo" id="detalle-tipo">SEMILLA</div>
            <div class="detalle-titulo" id="detalle-titulo">SURCO —</div>
          </div>
          <button class="detalle-close" onclick="MapUI.cerrarDetalle()">
            &times;
          </button>
        </div>
        <div class="detalle-body">
          <div class="detalle-spm-label">Densidad actual</div>
          <div class="detalle-spm-valor" id="detalle-spm-valor">—</div>
          <div class="detalle-spm-unidad">semillas / metro</div>
          <div class="detalle-barra-bg">
            <div
              class="detalle-barra-fill"
              id="detalle-barra"
              style="width: 0%; background: #00e676"
            ></div>
          </div>
          <div class="detalle-barra-labels">
            <span>0</span>
            <span id="detalle-barra-obj">Objetivo: —</span>
            <span id="detalle-barra-max">—</span>
          </div>
          <div
            id="detalle-tapado-aviso"
            class="detalle-tapado"
            style="display: none"
          >
            <i class="fas fa-exclamation-triangle"></i> SURCO TAPADO
          </div>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <!-- SCRIPTS — orden importa: Leaflet → Socket.IO → engine → ui -->
    <script src="/js/leaflet.min.js"></script>
