<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>VistaX - Monitor de Siembra</title>
    <link rel="stylesheet" href="/css/all.min.css" />
    <link rel="stylesheet" href="/css/vistax.css" />
  </head>
  <body>
    <div class="vistax-app">
      <%- include('partials/header') %>

      <main class="monitor-wrapper">
        <div class="monitor-grid" id="main-monitor"></div>
      </main>

      <%- include('partials/footer') %>
    </div>

    <%- include('partials/config_modal') %>

    <script>
      window.APP_CONFIG    = <%- JSON.stringify(config || {}) %>;
      window.LOTE_ACTIVO   = <%- JSON.stringify(loteActivo || null) %>;
      <%# Calculamos la cantidad de surcos de semilla para elegir modo de render %>
      window.TOTAL_SURCOS  = <%- (config && config.mapeo_sensores) ? config.mapeo_sensores.filter(s => s.tipo === 'semilla' || s.tipo === 'ferti_linea' || s.tipo === 'ferti_costado').length : 0 %>;
    </script>
    <script src="/socket.io/socket.io.js?v=3"></script>
    <script src="/js/render_engine.js?v=3"></script>
    <script src="/js/config_modal.js?v=3"></script>
  </body>
</html>
